cat > ~/.smwcs_temp_gitignore << 'EOF'
__pycache__/
.zip
*.py[cod]
*.pyo
venv/
.venv/
env/
*.egg-info/
.env
.env.local
.env.production
*.env
!.env.example
node_modules/
dist/
build/
.vite/
npm-debug.log*
docker-compose.override.yml
*.sqlite3
dump/
.vscode/
.idea/
*.swp
.DS_Store
logs/
*.log
*.pem
*.key
*.crt
certs/
*.h5
*.keras
*.pkl
models/
.pytest_cache/
.coverage
htmlcov/
EOF
cp ~/.smwcs_temp_gitignore ~/smwcs/.gitignore
